rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- AntiPay Gateway Rules (At Top for Priority) ---

    match /stores/{storeId} {
      // Allow API routes to query stores by apiKey field
      allow read: if true;
      allow write: if false; // Only via console/admin
    }

    match /payment_sessions/{sessionId} {
      // Public needs to read session info to show amount/details on checkout
      allow get: if true;
      allow list: if false;
      // API routes create/update sessions
      allow create, update: if true;
    }

    match /transactions/{trxId} {
      // Server-side verification needs to read/write
      allow read, write: if true;
    }

    // --- Existing System Rules (Preserved) ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      match /{allSubCollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }
    
    match /users {
      allow list: if isAdmin();
    }

    match /user_plans/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // This specific match for stores is already handled above in the AntiPay section
    // but preserving the original owner-based rules for management
    match /stores/{storeId} {
      allow get, update, delete: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isSignedIn();
      allow list: if isSignedIn() && (isAdmin() || request.query.limit <= 100);
    }
    
    match /subscriptionPlans/{planId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /plan_transactions/{txId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
    }

    match /devices/{brandId} {
      allow read, write: if isSignedIn();
    }

    // Global settings access
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{allPaths=**}/paymentSessions/{sessionId} {
      allow read: if isAdmin();
    }
  }
}